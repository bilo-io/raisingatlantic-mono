{
	"info": {
		"name": "Raising Atlantic API Collection",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Examples",
			"item": [
				{
					"name": "Create Example",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Sample Example\",\n    \"description\": \"A test description\"\n}"
						},
						"url": {
							"raw": "{{API_BASE_URL}}/{{API_VERSION}}/examples",
							"host": ["{{API_BASE_URL}}"],
							"path": ["{{API_VERSION}}", "examples"]
						}
					}
				},
				{
					"name": "Get All Examples",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{API_BASE_URL}}/{{API_VERSION}}/examples",
							"host": ["{{API_BASE_URL}}"],
							"path": ["{{API_VERSION}}", "examples"]
						}
					}
				},
				{
					"name": "Get Example By ID",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{API_BASE_URL}}/{{API_VERSION}}/examples/:id",
							"host": ["{{API_BASE_URL}}"],
							"path": ["{{API_VERSION}}", "examples", ":id"],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Update Example",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"Updated Example Name\"\n}"
						},
						"url": {
							"raw": "{{API_BASE_URL}}/{{API_VERSION}}/examples/:id",
							"host": ["{{API_BASE_URL}}"],
							"path": ["{{API_VERSION}}", "examples", ":id"],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Delete Example",
					"request": {
						"method": "DELETE",
						"url": {
							"raw": "{{API_BASE_URL}}/{{API_VERSION}}/examples/:id",
							"host": ["{{API_BASE_URL}}"],
							"path": ["{{API_VERSION}}", "examples", ":id"],
							"variable": [
								{
									"key": "id",
									"value": ""
								}
							]
						}
					}
				}
			]
		}
	]
}
